# Copy to .env.deploy and fill in. Do NOT commit.
# Used by scripts/deploy.sh — rotated keys are picked up on the next run.

# ─── GitHub ──────────────────────────────────────────────────────────────
# `gh` reads its own auth from `gh auth login` — no token needed here.
GITHUB_REPO=owner/content-studio
GITHUB_VISIBILITY=private        # public | private

# ─── Supabase ────────────────────────────────────────────────────────────
# Personal access token: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_...
# 20-char ID from your project URL: https://supabase.com/dashboard/project/<REF>
SUPABASE_PROJECT_REF=
# Database password: Project Settings → Database → "Reset database password"
SUPABASE_DB_PASSWORD=

# ─── Vercel ──────────────────────────────────────────────────────────────
# Token: https://vercel.com/account/tokens
VERCEL_TOKEN=
# Project name in Vercel — script creates it on first run if absent.
VERCEL_PROJECT=content-studio
# Team slug (from team settings URL); leave blank for personal scope.
VERCEL_SCOPE=

# ─── Public production URL ───────────────────────────────────────────────
# Used as NEXT_PUBLIC_SITE_URL and as the Supabase auth redirect.
PROD_URL=https://content-studio.vercel.app
